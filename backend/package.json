    "@types/tesseract.js": "^2.0.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "prisma": "^5.16.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
