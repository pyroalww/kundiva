{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "types": ["vite/client"],
    "module": "ESNext",
    "moduleResolution": "Node",
    "noEmit": true,
    "paths": {
      "@kundiva/shared": ["../shared/src"],
      "@kundiva/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
